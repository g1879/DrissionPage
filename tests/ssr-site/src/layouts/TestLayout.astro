---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'DrissionPage deterministic SSR test target' } = Astro.props;
const requestId = crypto.randomUUID();
const renderedAt = new Date().toISOString();
---
<!doctype html>
<html lang="en" data-page-title={title} data-request-id={requestId} data-rendered-at={renderedAt}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <style>
      :root { color-scheme: light dark; font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }
      body { margin: 0; background: #f7f8fb; color: #172033; }
      main { max-width: 1180px; margin: 0 auto; padding: 28px 20px 64px; }
      header { background: #172033; color: #fff; border-bottom: 4px solid #ff6a00; }
      header .wrap { max-width: 1180px; margin: 0 auto; padding: 16px 20px 14px; display: grid; gap: 12px; }
      .brand-row { display: flex; justify-content: space-between; gap: 16px; align-items: center; }
      .brand { display: flex; flex-direction: column; gap: 2px; }
      .brand strong { font-size: 18px; }
      .brand span { color: #b8c7df; font-size: 13px; }
      .top-badge { border: 1px solid rgba(255,255,255,.26); border-radius: 999px; padding: 6px 10px; color: #ffd7aa; background: rgba(255,255,255,.08); }
      nav { display: flex; flex-wrap: wrap; gap: 8px; }
      nav a { color: #d8e6ff; text-decoration: none; border: 1px solid rgba(216,230,255,.22); border-radius: 999px; padding: 7px 10px; background: rgba(255,255,255,.05); }
      nav a:hover { border-color: #ffb267; color: #fff; }
      h1, h2, h3 { line-height: 1.2; }
      .panel { background: #fff; border: 1px solid #d8deea; border-radius: 12px; padding: 18px; margin: 16px 0; box-shadow: 0 1px 2px rgba(20, 27, 43, .05); }
      .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 14px; }
      .case-link { display: block; padding: 14px; border: 1px solid #d8deea; border-radius: 10px; color: #172033; background: #fff; text-decoration: none; }
      .case-link:hover { border-color: #4b73ff; }
      code, pre { background: #eef2f8; border-radius: 6px; }
      code { padding: 2px 5px; }
      pre { padding: 12px; overflow: auto; }
      button, input, select, textarea { font: inherit; }
      button, .button { border: 0; border-radius: 8px; padding: 9px 12px; background: #315cff; color: white; cursor: pointer; }
      button.secondary { background: #4c5a70; }
      table { border-collapse: collapse; width: 100%; }
      th, td { border: 1px solid #d8deea; padding: 8px; text-align: left; }
      iframe { width: 100%; min-height: 180px; border: 2px solid #315cff; border-radius: 10px; }
      [data-test-highlight="true"] { outline: 3px solid #1aa96b; outline-offset: 2px; }
    </style>
  </head>
  <body>
    <header>
      <div class="wrap brand-row">
        <div class="brand">
          <strong data-testid="site-name">DrissionPage SSR Test Site</strong>
          <span>Scenario portal for deterministic browser, crawler, listener and business-flow checks</span>
        </div>
        <span class="top-badge" data-testid="site-mode">SSR fixture</span>
      </div>
      <div class="wrap" style="padding-top:0;">
        <nav aria-label="Primary">
          <a href="/" data-testid="nav-home">Overview</a>
          <a href="/scenarios/marketplace" data-testid="nav-marketplace">Marketplace flow</a>
          <a href="/cases/cloudflare-gate" data-testid="nav-security">Security gates</a>
          <a href="/cases/business-dashboard" data-testid="nav-business-dashboard">Business dashboard</a>
          <a href="/cases/locators" data-testid="nav-locators">Feature fixtures</a>
          <a href="/api/manifest.json" data-testid="nav-manifest">Manifest</a>
        </nav>
      </div>
    </header>
    <main data-testid="main" data-request-id={requestId} data-rendered-at={renderedAt}>
      <slot />
    </main>
  </body>
</html>
