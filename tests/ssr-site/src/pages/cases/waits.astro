---
import TestLayout from '../../layouts/TestLayout.astro';
---
<TestLayout title="Wait fixture">
  <section class="panel" data-testid="wait-root">
    <h1>Wait fixture</h1>
    <p>Deterministic timers mutate visibility, text, attributes, and DOM stability markers.</p>
    <div class="grid">
      <button type="button" id="start-waits" data-testid="start-waits">Start wait sequence</button>
      <button type="button" id="stabilize-html" data-testid="stabilize-html">Stabilize HTML</button>
    </div>
    <div id="delayed-visible" data-testid="delayed-visible" hidden>visible after timer</div>
    <div id="delayed-hidden" data-testid="delayed-hidden">hidden after timer</div>
    <div id="text-target" data-testid="text-target">initial</div>
    <div id="attr-target" data-testid="attr-target" data-state="initial">attribute target</div>
    <ul id="html-stable-list" data-testid="html-stable-list"><li>initial</li></ul>
    <output id="wait-output" data-testid="wait-output">idle</output>
  </section>
  <script>
    const start = document.querySelector<HTMLButtonElement>('#start-waits');
    const stabilize = document.querySelector<HTMLButtonElement>('#stabilize-html');
    const delayedVisible = document.querySelector<HTMLElement>('#delayed-visible');
    const delayedHidden = document.querySelector<HTMLElement>('#delayed-hidden');
    const textTarget = document.querySelector<HTMLElement>('#text-target');
    const attrTarget = document.querySelector<HTMLElement>('#attr-target');
    const list = document.querySelector<HTMLUListElement>('#html-stable-list');
    const output = document.querySelector<HTMLOutputElement>('#wait-output');

    start?.addEventListener('click', () => {
      if (!delayedVisible || !delayedHidden || !textTarget || !attrTarget || !output) return;
      output.textContent = 'running';
      delayedVisible.hidden = true;
      delayedHidden.hidden = false;
      textTarget.textContent = 'initial';
      attrTarget.dataset.state = 'initial';
      window.setTimeout(() => { delayedVisible.hidden = false; output.textContent = 'visible-ready'; }, 120);
      window.setTimeout(() => { delayedHidden.hidden = true; output.textContent = 'hidden-ready'; }, 220);
      window.setTimeout(() => { textTarget.textContent = 'text-ready'; attrTarget.dataset.state = 'ready'; output.textContent = 'all-ready'; }, 320);
    });

    stabilize?.addEventListener('click', () => {
      if (!list || !output) return;
      list.dataset.stable = 'false';
      output.textContent = 'stabilizing';
      let count = 0;
      const timer = window.setInterval(() => {
        count += 1;
        const item = document.createElement('li');
        item.textContent = `tick-${count}`;
        list.appendChild(item);
        if (count >= 3) {
          window.clearInterval(timer);
          list.dataset.stable = 'true';
          output.textContent = 'stable-ready';
        }
      }, 90);
    });
  </script>
</TestLayout>
