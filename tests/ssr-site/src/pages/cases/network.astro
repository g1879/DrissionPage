---
import TestLayout from '../../layouts/TestLayout.astro';
const wsUrl = import.meta.env.PUBLIC_OPTIONAL_WS_URL || '';
---
<TestLayout title="Network fixture">
  <section class="panel" data-testid="network-root">
    <h1>Network fixture</h1>
    <p>Buttons below trigger deterministic requests for listener tests.</p>
    <div class="grid">
      <button type="button" id="fetch-json" data-testid="fetch-json">Fetch JSON</button>
      <button type="button" id="post-echo" data-testid="post-echo">POST echo</button>
      <button type="button" id="start-sse" data-testid="start-sse">Start SSE</button>
      <button type="button" id="start-ws" data-testid="start-ws">Start optional WebSocket</button>
    </div>
    <pre id="network-log" data-testid="network-log" aria-live="polite">ready</pre>
  </section>
  <script is:inline define:vars={{ wsUrl }}>
    const log = document.querySelector('#network-log');
    const write = (entry) => {
      log.textContent = `${new Date().toISOString()} ${entry}\n${log.textContent}`;
    };

    document.querySelector('#fetch-json')?.addEventListener('click', async () => {
      const res = await fetch('/api/echo.json?from=fetch-json', { headers: { 'x-dp-test': 'fetch-json' } });
      write(`fetch-json status=${res.status} body=${JSON.stringify(await res.json())}`);
    });

    document.querySelector('#post-echo')?.addEventListener('click', async () => {
      const res = await fetch('/api/echo.json', {
        method: 'POST',
        headers: { 'content-type': 'application/json', 'x-dp-test': 'post-echo' },
        body: JSON.stringify({ message: 'hello from DrissionPage', count: 2 }),
      });
      write(`post-echo status=${res.status} body=${JSON.stringify(await res.json())}`);
    });

    document.querySelector('#start-sse')?.addEventListener('click', () => {
      const source = new EventSource('/api/events?count=3&interval=50');
      source.addEventListener('check', (event) => write(`sse check id=${event.lastEventId} data=${event.data}`));
      source.addEventListener('done', () => { write('sse done'); source.close(); });
      source.onerror = () => { write('sse error'); source.close(); };
    });

    document.querySelector('#start-ws')?.addEventListener('click', () => {
      if (!wsUrl) {
        write('websocket skipped: optional endpoint is not configured');
        return;
      }
      const socket = new WebSocket(wsUrl);
      socket.addEventListener('open', () => { write('websocket open'); socket.send('drissionpage-ws-check'); });
      socket.addEventListener('message', (event) => { write(`websocket message=${event.data}`); socket.close(); });
      socket.addEventListener('error', () => write('websocket error'));
      socket.addEventListener('close', () => write('websocket close'));
    });
  </script>
</TestLayout>
