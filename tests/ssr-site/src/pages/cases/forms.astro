---
import TestLayout from '../../layouts/TestLayout.astro';
---
<TestLayout title="Form fixture">
  <section class="panel" data-testid="form-root">
    <h1>Form fixture</h1>
    <form id="profile-form" action="/api/echo.json" method="post" data-testid="profile-form">
      <label>Name <input id="name" name="name" autocomplete="off" value="initial" data-testid="name-input" /></label>
      <label>Mode
        <select id="mode" name="mode" data-testid="mode-select">
          <option value="alpha">alpha</option>
          <option value="beta">beta</option>
        </select>
      </label>
      <label><input id="agree" name="agree" type="checkbox" data-testid="agree-checkbox" /> Agree</label>
      <button type="submit" data-testid="submit-button">Submit</button>
      <button type="button" id="multi-click" class="secondary" data-testid="multi-click">Multi click target</button>
    </form>
    <output id="form-output" data-testid="form-output">idle</output>
  </section>
  <script>
    let clicks = 0;
    const form = document.querySelector<HTMLFormElement>('#profile-form');
    const output = document.querySelector<HTMLOutputElement>('#form-output');
    const multiClick = document.querySelector<HTMLButtonElement>('#multi-click');

    form?.addEventListener('submit', async (event: SubmitEvent) => {
      event.preventDefault();
      const currentForm = event.currentTarget;
      if (!(currentForm instanceof HTMLFormElement) || !output) return;
      const body = Object.fromEntries(new FormData(currentForm));
      const res = await fetch('/api/echo.json', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify(body),
      });
      output.textContent = JSON.stringify(await res.json());
    });

    multiClick?.addEventListener('click', (event: MouseEvent) => {
      const target = event.currentTarget;
      if (!(target instanceof HTMLButtonElement) || !output) return;
      clicks += 1;
      target.dataset.clicks = String(clicks);
      output.textContent = `clicks=${clicks}; detail=${event.detail}`;
    });
  </script>
</TestLayout>
