---
import TestLayout from '../../layouts/TestLayout.astro';
import { makeActivities, summarizeActivities } from '../../lib/activities';

const activities = makeActivities(120);
const summary = summarizeActivities(activities);
---
<TestLayout title="Business dashboard fixture">
  <section class="panel" data-testid="business-root" data-total={activities.length} data-active={summary.active} data-pending={summary.pending} data-blocked={summary.blocked}>
    <h1>Business dashboard fixture</h1>
    <p>High-volume fixture with filters, batch selection, incremental loading, and burst network requests.</p>
    <div class="grid" aria-label="Summary cards">
      <article data-testid="summary-active" data-count={summary.active}><strong>Active</strong><span>{summary.active}</span></article>
      <article data-testid="summary-pending" data-count={summary.pending}><strong>Pending</strong><span>{summary.pending}</span></article>
      <article data-testid="summary-blocked" data-count={summary.blocked}><strong>Blocked</strong><span>{summary.blocked}</span></article>
    </div>
  </section>

  <section class="panel" data-testid="business-controls">
    <label>Search <input id="business-search" data-testid="business-search" autocomplete="off" placeholder="Activity 042" /></label>
    <label>Status
      <select id="status-filter" data-testid="status-filter">
        <option value="all">all</option>
        <option value="active">active</option>
        <option value="pending">pending</option>
        <option value="blocked">blocked</option>
      </select>
    </label>
    <button type="button" id="select-visible" data-testid="select-visible">Select visible</button>
    <button type="button" id="load-more" class="secondary" data-testid="load-more">Load more</button>
    <button type="button" id="burst-fetch" class="secondary" data-testid="burst-fetch">Run burst fetch</button>
    <output id="business-output" data-testid="business-output">ready</output>
  </section>

  <section class="panel" data-testid="business-table-panel">
    <table data-testid="business-table">
      <thead>
        <tr>
          <th scope="col">Select</th>
          <th scope="col">Title</th>
          <th scope="col">Status</th>
          <th scope="col">Priority</th>
          <th scope="col">Owner</th>
          <th scope="col">Amount</th>
        </tr>
      </thead>
      <tbody id="activity-body" data-testid="activity-body">
        {activities.map((item) => (
          <tr data-testid="activity-row" data-id={item.id} data-status={item.status} data-priority={item.priority} data-owner={item.owner}>
            <td><input type="checkbox" data-testid="activity-select" aria-label={`Select ${item.title}`} /></td>
            <td><a href={`/cases/dynamic?name=${encodeURIComponent(item.title)}`} data-testid="activity-link">{item.title}</a></td>
            <td data-testid="activity-status">{item.status}</td>
            <td>{item.priority}</td>
            <td>{item.owner}</td>
            <td data-testid="activity-amount">{item.amount}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </section>

  <script>
    const search = document.querySelector<HTMLInputElement>('#business-search');
    const statusFilter = document.querySelector<HTMLSelectElement>('#status-filter');
    const output = document.querySelector<HTMLOutputElement>('#business-output');
    const body = document.querySelector<HTMLTableSectionElement>('#activity-body');
    const selectVisible = document.querySelector<HTMLButtonElement>('#select-visible');
    const loadMore = document.querySelector<HTMLButtonElement>('#load-more');
    const burstFetch = document.querySelector<HTMLButtonElement>('#burst-fetch');
    const loadedIds = new Set(Array.from(document.querySelectorAll<HTMLTableRowElement>('[data-testid="activity-row"]')).map((row) => row.dataset.id || ''));

    function rows() {
      return Array.from(document.querySelectorAll<HTMLTableRowElement>('[data-testid="activity-row"]'));
    }

    function visibleRows() {
      return rows().filter((row) => !row.hidden);
    }

    function write(message: string) {
      if (output) output.textContent = message;
    }

    function applyFilters() {
      const query = (search?.value || '').trim().toLowerCase();
      const status = statusFilter?.value || 'all';
      let visible = 0;
      for (const row of rows()) {
        const text = row.textContent?.toLowerCase() || '';
        const okQuery = !query || text.includes(query);
        const okStatus = status === 'all' || row.dataset.status === status;
        row.hidden = !(okQuery && okStatus);
        if (!row.hidden) visible += 1;
      }
      write(`visible=${visible}; selected=${document.querySelectorAll('[data-testid="activity-select"]:checked').length}`);
    }

    search?.addEventListener('input', applyFilters);
    statusFilter?.addEventListener('change', applyFilters);

    selectVisible?.addEventListener('click', () => {
      for (const row of visibleRows()) {
        row.querySelector<HTMLInputElement>('[data-testid="activity-select"]')!.checked = true;
      }
      write(`visible=${visibleRows().length}; selected=${document.querySelectorAll('[data-testid="activity-select"]:checked').length}`);
    });

    loadMore?.addEventListener('click', async () => {
      const res = await fetch(`/api/activity-batch.json?offset=${loadedIds.size}&count=8&delay=20`, { headers: { 'x-dp-test': 'activity-load-more' } });
      const data = await res.json();
      if (!body) return;
      for (const item of data.items) {
        if (loadedIds.has(String(item.id))) continue;
        loadedIds.add(String(item.id));
        const row = document.createElement('tr');
        row.dataset.testid = 'activity-row';
        row.dataset.id = String(item.id);
        row.dataset.status = item.status;
        row.dataset.priority = item.priority;
        row.dataset.owner = item.owner;
        row.innerHTML = `<td><input type="checkbox" data-testid="activity-select" aria-label="Select ${item.title}" /></td><td><a href="/cases/dynamic?name=${encodeURIComponent(item.title)}" data-testid="activity-link">${item.title}</a></td><td data-testid="activity-status">${item.status}</td><td>${item.priority}</td><td>${item.owner}</td><td data-testid="activity-amount">${item.amount}</td>`;
        body.appendChild(row);
      }
      applyFilters();
      write(`loaded=${data.count}; total=${rows().length}; next=${data.nextOffset}`);
    });

    burstFetch?.addEventListener('click', async () => {
      const requests = Array.from({ length: 6 }, (_, index) => fetch(`/api/activity-batch.json?offset=${index * 3}&count=3&delay=${10 + index}`, { headers: { 'x-dp-test': `activity-burst-${index}` } }).then((res) => res.json()));
      const batches = await Promise.all(requests);
      const total = batches.reduce((sum, batch) => sum + batch.count, 0);
      write(`burst=${batches.length}; items=${total}`);
    });
  </script>
</TestLayout>
