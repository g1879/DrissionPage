---
import TestLayout from '../../layouts/TestLayout.astro';
---
<TestLayout title="Visual fixture">
  <section class="panel" data-testid="visual-root">
    <h1>Visual fixture</h1>
    <p>Fixed color bands and green anchor dots for screenshot and visual-regression checks.</p>
    <div id="visual-target" data-testid="visual-target" aria-label="visual screenshot target">
      <span class="dot top-left" data-testid="dot-top-left"></span>
      <span class="dot top-right" data-testid="dot-top-right"></span>
      <span class="dot bottom-left" data-testid="dot-bottom-left"></span>
      <span class="dot bottom-right" data-testid="dot-bottom-right"></span>
      <div class="band band-red" data-testid="band-red">red band</div>
      <div class="band band-green" data-testid="band-green">green band</div>
      <div class="band band-blue" data-testid="band-blue">blue band</div>
    </div>
    <div id="long-visual-target" data-testid="long-visual-target">
      {Array.from({ length: 12 }).map((_, index) => <div class={`long-row row-${index % 3}`}>row {index + 1}</div>)}
    </div>
  </section>
  <style>
    #visual-target {
      position: relative;
      width: 360px;
      height: 240px;
      border: 8px solid #111827;
      border-radius: 4px;
      overflow: hidden;
      background: #ffffff;
    }
    .band { height: 80px; display: flex; align-items: center; justify-content: center; font-weight: 700; color: #ffffff; }
    .band-red { background: #dc2626; }
    .band-green { background: #16a34a; }
    .band-blue { background: #2563eb; }
    .dot { position: absolute; z-index: 2; width: 16px; height: 16px; border-radius: 999px; background: #00ff00; border: 2px solid #003300; }
    .top-left { top: 8px; left: 8px; }
    .top-right { top: 8px; right: 8px; }
    .bottom-left { bottom: 8px; left: 8px; }
    .bottom-right { bottom: 8px; right: 8px; }
    #long-visual-target { margin-top: 24px; width: 360px; border: 4px solid #4c5a70; }
    .long-row { height: 120px; display: flex; align-items: center; padding-left: 16px; font-weight: 700; }
    .row-0 { background: #fde68a; color: #422006; }
    .row-1 { background: #bfdbfe; color: #1e3a8a; }
    .row-2 { background: #fecaca; color: #7f1d1d; }
  </style>
</TestLayout>
