---
import TestLayout from '../../layouts/TestLayout.astro';
import { makeProducts, summarizeProducts } from '../../lib/products';

const products = makeProducts(60);
const summary = summarizeProducts(products);
---
<TestLayout title="Commerce workflow fixture">
  <section class="panel" data-testid="commerce-root" data-total={products.length} data-in-stock={summary.inStock} data-sold-out={summary.soldOut}>
    <h1>Commerce workflow fixture</h1>
    <p>Deterministic storefront flow with facets, sorted catalog results, lazy loading, recommendation requests, cart drawer, and checkout modal.</p>
    <div class="grid" aria-label="Commerce summary">
      <article data-testid="commerce-summary-total" data-count={summary.total}><strong>Total</strong><span>{summary.total}</span></article>
      <article data-testid="commerce-summary-stock" data-count={summary.inStock}><strong>Sellable</strong><span>{summary.inStock}</span></article>
      <article data-testid="commerce-summary-electronics" data-count={summary.electronics}><strong>Electronics</strong><span>{summary.electronics}</span></article>
    </div>
  </section>

  <section class="panel" data-testid="commerce-controls">
    <label>Search <input id="commerce-search" data-testid="commerce-search" autocomplete="off" placeholder="Fixture Product 012" /></label>
    <label>Category
      <select id="commerce-category" data-testid="commerce-category">
        <option value="all">all</option>
        <option value="electronics">electronics</option>
        <option value="apparel">apparel</option>
        <option value="home">home</option>
        <option value="outdoor">outdoor</option>
      </select>
    </label>
    <label>Sort
      <select id="commerce-sort" data-testid="commerce-sort">
        <option value="id">id</option>
        <option value="price-asc">price asc</option>
        <option value="price-desc">price desc</option>
        <option value="rating-desc">rating desc</option>
      </select>
    </label>
    <button type="button" id="commerce-load-more" class="secondary" data-testid="commerce-load-more">Load more products</button>
    <button type="button" id="commerce-recommend" class="secondary" data-testid="commerce-recommend">Load recommendations</button>
    <button type="button" id="open-checkout" data-testid="open-checkout">Open checkout</button>
    <output id="commerce-output" data-testid="commerce-output">visible=60; cart=0</output>
  </section>

  <section class="panel" data-testid="commerce-results-panel">
    <div id="commerce-grid" data-testid="commerce-grid" class="product-grid">
      {products.map((product) => (
        <article class="product-card" data-testid="product-card" data-id={product.id} data-sku={product.sku} data-category={product.category} data-price={product.price} data-rating={product.rating} data-stock={product.stock}>
          <h2 data-testid="product-title">{product.title}</h2>
          <p><span data-testid="product-category">{product.category}</span> · <span data-testid="product-stock">{product.stock}</span></p>
          <p><strong data-testid="product-price">{product.price}</strong> credits · rating <span data-testid="product-rating">{product.rating}</span></p>
          <label>Variant
            <select data-testid="product-variant">
              {product.variants.map((variant) => <option value={variant}>{variant}</option>)}
            </select>
          </label>
          <button type="button" data-testid="add-to-cart" disabled={product.stock === 'sold_out'}>Add to cart</button>
        </article>
      ))}
    </div>
  </section>

  <aside id="cart-drawer" class="panel" data-testid="cart-drawer" aria-live="polite">
    <h2>Cart drawer</h2>
    <ul id="cart-lines" data-testid="cart-lines"></ul>
    <output id="cart-output" data-testid="cart-output">cart=0; subtotal=0</output>
  </aside>

  <section class="panel" data-testid="recommendations-panel">
    <h2>Recommendations</h2>
    <div id="recommendations" data-testid="recommendations">idle</div>
  </section>

  <dialog id="checkout-dialog" data-testid="checkout-dialog">
    <form method="dialog" id="checkout-form" data-testid="checkout-form">
      <h2>Checkout</h2>
      <label>Email <input id="checkout-email" data-testid="checkout-email" type="email" value="buyer@example.test" /></label>
      <label>Address <textarea id="checkout-address" data-testid="checkout-address">1 Fixture Street</textarea></label>
      <button type="submit" data-testid="checkout-submit">Reserve order</button>
      <button type="button" class="secondary" id="checkout-close" data-testid="checkout-close">Close</button>
      <output id="checkout-output" data-testid="checkout-output">idle</output>
    </form>
  </dialog>

  <style>
    .product-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 12px; }
    .product-card { border: 1px solid #d8deea; border-radius: 10px; padding: 12px; background: #fff; }
    .product-card[hidden] { display: none; }
    .product-card[data-stock="sold_out"] { opacity: .58; }
    #cart-drawer { position: sticky; bottom: 12px; }
    dialog { border: 1px solid #d8deea; border-radius: 12px; padding: 18px; min-width: 320px; }
    dialog::backdrop { background: rgba(23, 32, 51, .35); }
  </style>

  <script>
    type CartLine = { id: number; title: string; quantity: number; subtotal: number; variant: string };

    const search = document.querySelector<HTMLInputElement>('#commerce-search');
    const category = document.querySelector<HTMLSelectElement>('#commerce-category');
    const sort = document.querySelector<HTMLSelectElement>('#commerce-sort');
    const grid = document.querySelector<HTMLElement>('#commerce-grid');
    const output = document.querySelector<HTMLOutputElement>('#commerce-output');
    const loadMore = document.querySelector<HTMLButtonElement>('#commerce-load-more');
    const recommend = document.querySelector<HTMLButtonElement>('#commerce-recommend');
    const recommendations = document.querySelector<HTMLElement>('#recommendations');
    const cartLines = document.querySelector<HTMLUListElement>('#cart-lines');
    const cartOutput = document.querySelector<HTMLOutputElement>('#cart-output');
    const checkoutDialog = document.querySelector<HTMLDialogElement>('#checkout-dialog');
    const checkoutForm = document.querySelector<HTMLFormElement>('#checkout-form');
    const checkoutEmail = document.querySelector<HTMLInputElement>('#checkout-email');
    const checkoutAddress = document.querySelector<HTMLTextAreaElement>('#checkout-address');
    const checkoutOutput = document.querySelector<HTMLOutputElement>('#checkout-output');
    const cart: CartLine[] = [];
    const loadedIds = new Set(Array.from(document.querySelectorAll<HTMLElement>('[data-testid="product-card"]')).map((card) => card.dataset.id || ''));

    function cards() {
      return Array.from(document.querySelectorAll<HTMLElement>('[data-testid="product-card"]'));
    }

    function visibleCards() {
      return cards().filter((card) => !card.hidden);
    }

    function write(message: string) {
      if (output) output.textContent = message;
    }

    function applyFilters() {
      const query = (search?.value || '').trim().toLowerCase();
      const selectedCategory = category?.value || 'all';
      const selectedSort = sort?.value || 'id';
      const items = cards();
      for (const card of items) {
        const okQuery = !query || (card.textContent || '').toLowerCase().includes(query);
        const okCategory = selectedCategory === 'all' || card.dataset.category === selectedCategory;
        card.hidden = !(okQuery && okCategory);
      }
      const sorted = visibleCards().sort((a, b) => {
        if (selectedSort === 'price-asc') return Number(a.dataset.price) - Number(b.dataset.price);
        if (selectedSort === 'price-desc') return Number(b.dataset.price) - Number(a.dataset.price);
        if (selectedSort === 'rating-desc') return Number(b.dataset.rating) - Number(a.dataset.rating);
        return Number(a.dataset.id) - Number(b.dataset.id);
      });
      for (const card of sorted) grid?.appendChild(card);
      write(`visible=${visibleCards().length}; cart=${cart.length}`);
    }

    function renderCart() {
      if (!cartLines || !cartOutput) return;
      cartLines.innerHTML = '';
      let subtotal = 0;
      for (const line of cart) {
        subtotal += line.subtotal;
        const item = document.createElement('li');
        item.dataset.testid = 'cart-line';
        item.textContent = `${line.title} / ${line.variant} / qty=${line.quantity} / subtotal=${line.subtotal}`;
        cartLines.appendChild(item);
      }
      cartOutput.textContent = `cart=${cart.length}; subtotal=${subtotal}`;
      write(`visible=${visibleCards().length}; cart=${cart.length}`);
    }

    function productCardHtml(product: any) {
      const options = product.variants.map((variant: string) => `<option value="${variant}">${variant}</option>`).join('');
      return `<article class="product-card" data-testid="product-card" data-id="${product.id}" data-sku="${product.sku}" data-category="${product.category}" data-price="${product.price}" data-rating="${product.rating}" data-stock="${product.stock}"><h2 data-testid="product-title">${product.title}</h2><p><span data-testid="product-category">${product.category}</span> · <span data-testid="product-stock">${product.stock}</span></p><p><strong data-testid="product-price">${product.price}</strong> credits · rating <span data-testid="product-rating">${product.rating}</span></p><label>Variant <select data-testid="product-variant">${options}</select></label><button type="button" data-testid="add-to-cart" ${product.stock === 'sold_out' ? 'disabled' : ''}>Add to cart</button></article>`;
    }

    search?.addEventListener('input', applyFilters);
    category?.addEventListener('change', applyFilters);
    sort?.addEventListener('change', applyFilters);

    grid?.addEventListener('click', async (event: MouseEvent) => {
      const button = (event.target as HTMLElement).closest<HTMLButtonElement>('[data-testid="add-to-cart"]');
      if (!button) return;
      const card = button.closest<HTMLElement>('[data-testid="product-card"]');
      const variant = card?.querySelector<HTMLSelectElement>('[data-testid="product-variant"]')?.value || 'standard';
      const id = Number(card?.dataset.id || 1);
      const res = await fetch('/api/commerce/cart.json', {
        method: 'POST',
        headers: { 'content-type': 'application/json', 'x-dp-test': 'commerce-cart' },
        body: JSON.stringify({ id, variant, quantity: 1 }),
      });
      const data = await res.json();
      cart.push(data.line);
      renderCart();
    });

    loadMore?.addEventListener('click', async () => {
      const res = await fetch(`/api/commerce/products.json?offset=${loadedIds.size}&count=20&delay=20`, { headers: { 'x-dp-test': 'commerce-load-more' } });
      const data = await res.json();
      for (const item of data.items) {
        if (loadedIds.has(String(item.id))) continue;
        loadedIds.add(String(item.id));
        grid?.insertAdjacentHTML('beforeend', productCardHtml(item));
      }
      applyFilters();
      write(`loaded=${data.count}; total=${cards().length}; next=${data.nextOffset}`);
    });

    recommend?.addEventListener('click', async () => {
      const seed = cart[0]?.id || visibleCards()[0]?.dataset.id || '1';
      const res = await fetch(`/api/commerce/recommendations.json?seed=${seed}&count=4&delay=15`, { headers: { 'x-dp-test': 'commerce-recommend' } });
      const data = await res.json();
      if (recommendations) recommendations.textContent = `recommendations=${data.items.length}; seed=${data.seed}`;
    });

    document.querySelector('#open-checkout')?.addEventListener('click', () => checkoutDialog?.showModal());
    document.querySelector('#checkout-close')?.addEventListener('click', () => checkoutDialog?.close());
    checkoutForm?.addEventListener('submit', async (event: SubmitEvent) => {
      event.preventDefault();
      if (!checkoutOutput) return;
      const res = await fetch('/api/commerce/checkout.json', {
        method: 'POST',
        headers: { 'content-type': 'application/json', 'x-dp-test': 'commerce-checkout' },
        body: JSON.stringify({ email: checkoutEmail?.value, address: checkoutAddress?.value, items: cart }),
      });
      const data = await res.json();
      checkoutOutput.textContent = `order=${data.orderId}; status=${data.status}; items=${data.itemCount}`;
    });
  </script>
</TestLayout>
