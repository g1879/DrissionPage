---
import TestLayout from '../../layouts/TestLayout.astro';
---
<TestLayout title="Upload and download fixture">
  <section class="panel" data-testid="upload-download-root">
    <h1>Upload and download fixture</h1>
    <form id="upload-form" data-testid="upload-form">
      <label>Upload file <input id="file-input" name="file" type="file" data-testid="file-input" /></label>
      <button type="submit" data-testid="upload-submit">Echo upload metadata</button>
    </form>
    <a class="button" id="download-link" data-testid="download-link" href="/api/download.txt?name=dp-fixture.txt">Download text fixture</a>
    <output id="upload-output" data-testid="upload-output">idle</output>
  </section>
  <script>
    const form = document.querySelector<HTMLFormElement>('#upload-form');
    const fileInput = document.querySelector<HTMLInputElement>('#file-input');
    const output = document.querySelector<HTMLOutputElement>('#upload-output');

    form?.addEventListener('submit', (event: SubmitEvent) => {
      event.preventDefault();
      if (!fileInput || !output) return;
      const file = fileInput.files?.[0];
      if (!file) {
        output.textContent = 'no-file';
        return;
      }
      output.textContent = JSON.stringify({ name: file.name, size: file.size, type: file.type || 'unknown' });
    });
  </script>
</TestLayout>
