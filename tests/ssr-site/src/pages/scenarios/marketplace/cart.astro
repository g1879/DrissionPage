---
import ScenarioLayout from '../../../layouts/ScenarioLayout.astro';
import { makeMarketplaceItem, marketplaceSteps, marketplaceSubtotal } from '../../../lib/marketplace';

const cookieItemId = Number(Astro.cookies.get('marketplace_cart_item_id')?.value || 2);
const itemId = Math.max(Number(Astro.url.searchParams.get('id') || cookieItemId || 2), 1);
const quantity = Math.min(Math.max(Number(Astro.url.searchParams.get('qty') || Astro.cookies.get('marketplace_cart_count')?.value || 1), 1), 9);
const color = Astro.cookies.get('marketplace_cart_color')?.value || '奶油白';
const spec = Astro.cookies.get('marketplace_cart_spec')?.value || '标准款';
const item = makeMarketplaceItem(itemId);
const subtotal = marketplaceSubtotal(item, quantity);
const steps = marketplaceSteps(item.id);
const coverage = [
  { label: '购物车状态', value: 'cookie 恢复、勾选、数量调整、金额重算' },
  { label: '定位', value: '商品行、SKU、价格、汇总区和结算入口' },
  { label: '表单行为', value: 'checkbox / number input / plus-minus controls' },
  { label: '链路', value: '详情页加入购物车后进入结算页' },
];
---
<ScenarioLayout title="Marketplace cart" eyebrow="Step 4" summary="购物车页模拟大型电商的商品行、选择状态、数量调整、金额汇总和结算入口。" scenarioId="marketplace-cart" steps={steps} coverage={coverage}>
  <section class="cart-shell" data-testid="marketplace-cart-root" data-id={item.id} data-initial-quantity={quantity}>
    <div class="panel cart-list" data-testid="marketplace-cart-list">
      <div class="cart-toolbar">
        <label><input id="select-all" data-testid="marketplace-cart-select-all" type="checkbox" checked /> 全选</label>
        <span>店铺：<strong data-testid="marketplace-cart-shop">{item.shop}</strong></span>
      </div>

      <article class="cart-line" data-testid="marketplace-cart-line" data-unit-price={item.price} data-id={item.id}>
        <label class="line-check"><input id="line-selected" data-testid="marketplace-cart-line-checkbox" type="checkbox" checked /></label>
        <a class="line-thumb" href={`/scenarios/marketplace/item/${item.id}`} data-testid="marketplace-cart-thumb" style={`--hero:${item.heroColor}`}>{item.category}</a>
        <div class="line-main">
          <a href={`/scenarios/marketplace/item/${item.id}`} data-testid="marketplace-cart-title">{item.title}</a>
          <p data-testid="marketplace-cart-sku">{color} / {spec}</p>
          <small>{item.services.join(' · ')}</small>
        </div>
        <div class="line-price" data-testid="marketplace-cart-unit-price">¥{item.price}</div>
        <div class="quantity-box" data-testid="marketplace-cart-quantity-box">
          <button type="button" id="qty-minus" class="secondary" data-testid="marketplace-cart-qty-minus">-</button>
          <input id="cart-quantity" data-testid="marketplace-cart-quantity" type="number" min="1" max="9" value={quantity} />
          <button type="button" id="qty-plus" class="secondary" data-testid="marketplace-cart-qty-plus">+</button>
        </div>
        <strong class="line-total" id="line-total" data-testid="marketplace-cart-line-total">¥{subtotal}</strong>
      </article>
    </div>

    <aside class="panel cart-summary" data-testid="marketplace-cart-summary" data-subtotal={subtotal}>
      <h2>订单汇总</h2>
      <dl>
        <div><dt>商品件数</dt><dd id="summary-items" data-testid="marketplace-cart-summary-items">1</dd></div>
        <div><dt>商品数量</dt><dd id="summary-quantity" data-testid="marketplace-cart-summary-quantity">{quantity}</dd></div>
        <div><dt>商品金额</dt><dd id="summary-subtotal" data-testid="marketplace-cart-summary-subtotal">¥{subtotal}</dd></div>
        <div><dt>运费</dt><dd>¥0</dd></div>
      </dl>
      <output id="cart-output" data-testid="marketplace-cart-output">items=1; quantity={quantity}; total={subtotal}; selected=true</output>
      <a id="go-checkout" class="button" href={`/scenarios/marketplace/checkout?item=${item.id}&qty=${quantity}&total=${subtotal}`} data-testid="marketplace-cart-checkout">去结算</a>
    </aside>
  </section>

  <script define:vars={{ itemId: item.id, unitPrice: item.price }} is:inline>
    const selected = document.querySelector('#line-selected');
    const selectAll = document.querySelector('#select-all');
    const quantity = document.querySelector('#cart-quantity');
    const minus = document.querySelector('#qty-minus');
    const plus = document.querySelector('#qty-plus');
    const lineTotal = document.querySelector('#line-total');
    const summaryItems = document.querySelector('#summary-items');
    const summaryQuantity = document.querySelector('#summary-quantity');
    const summarySubtotal = document.querySelector('#summary-subtotal');
    const output = document.querySelector('#cart-output');
    const checkout = document.querySelector('#go-checkout');

    function clampQuantity(value) {
      return Math.min(Math.max(Number(value || 1), 1), 9);
    }

    function renderSummary() {
      const qty = clampQuantity(quantity.value);
      quantity.value = String(qty);
      const isSelected = Boolean(selected.checked);
      const items = isSelected ? 1 : 0;
      const total = isSelected ? Number((unitPrice * qty).toFixed(2)) : 0;
      lineTotal.textContent = `¥${total}`;
      summaryItems.textContent = String(items);
      summaryQuantity.textContent = String(isSelected ? qty : 0);
      summarySubtotal.textContent = `¥${total}`;
      output.textContent = `items=${items}; quantity=${isSelected ? qty : 0}; total=${total}; selected=${isSelected}`;
      checkout.href = `/scenarios/marketplace/checkout?item=${itemId}&qty=${qty}&total=${total}`;
      checkout.setAttribute('aria-disabled', isSelected ? 'false' : 'true');
    }

    selected?.addEventListener('change', () => {
      if (selectAll) selectAll.checked = selected.checked;
      renderSummary();
    });
    selectAll?.addEventListener('change', () => {
      if (selected) selected.checked = selectAll.checked;
      renderSummary();
    });
    quantity?.addEventListener('input', renderSummary);
    minus?.addEventListener('click', () => { quantity.value = String(clampQuantity(Number(quantity.value) - 1)); renderSummary(); });
    plus?.addEventListener('click', () => { quantity.value = String(clampQuantity(Number(quantity.value) + 1)); renderSummary(); });
    renderSummary();
  </script>

  <style>
    .cart-shell { display: grid; grid-template-columns: minmax(0, 1fr) 320px; gap: 18px; align-items: start; }
    .cart-list, .cart-summary { margin-top: 0; }
    .cart-toolbar { display: flex; gap: 18px; align-items: center; padding-bottom: 12px; border-bottom: 1px solid #e2e8f0; }
    .cart-line { display: grid; grid-template-columns: 36px 116px minmax(0, 1fr) 90px 150px 100px; gap: 14px; align-items: center; padding: 18px 0; border-bottom: 1px solid #e2e8f0; }
    .line-thumb { display: grid; place-items: center; min-height: 96px; border-radius: 14px; color: #fff; font-weight: 800; text-decoration: none; background: linear-gradient(135deg, var(--hero), #111827); }
    .line-main { display: grid; gap: 6px; }
    .line-main a { color: #172033; font-weight: 800; text-decoration: none; }
    .line-main p, .line-main small { margin: 0; color: #64748b; }
    .line-price, .line-total { color: #ea580c; }
    .quantity-box { display: grid; grid-template-columns: 38px 1fr 38px; gap: 6px; }
    .quantity-box input { width: 100%; border: 1px solid #cbd5e1; border-radius: 8px; padding: 8px; text-align: center; }
    .cart-summary { position: sticky; top: 18px; display: grid; gap: 12px; border-color: #fed7aa; }
    .cart-summary dl { display: grid; gap: 10px; }
    .cart-summary dl div { display: flex; justify-content: space-between; gap: 12px; }
    .cart-summary dt { color: #64748b; }
    .cart-summary dd { margin: 0; font-weight: 800; }
    .cart-summary output { padding: 10px; border-radius: 10px; color: #9a3412; background: #fff7ed; }
    .cart-summary .button { text-align: center; text-decoration: none; background: #ea580c; }
    @media (max-width: 960px) { .cart-shell, .cart-line { grid-template-columns: 1fr; } .cart-summary { position: static; } }
  </style>
</ScenarioLayout>
