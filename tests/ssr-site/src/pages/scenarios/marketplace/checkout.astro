---
import ScenarioLayout from '../../../layouts/ScenarioLayout.astro';
import {
  makeMarketplaceItem,
  marketplaceAddresses,
  marketplaceInvoices,
  marketplacePayments,
  marketplaceSteps,
  marketplaceSubtotal,
} from '../../../lib/marketplace';

const cookieItemId = Number(Astro.cookies.get('marketplace_cart_item_id')?.value || 2);
const itemId = Math.max(Number(Astro.url.searchParams.get('item') || cookieItemId || 2), 1);
const quantity = Math.min(Math.max(Number(Astro.url.searchParams.get('qty') || Astro.cookies.get('marketplace_cart_count')?.value || 1), 1), 9);
const item = makeMarketplaceItem(itemId);
const queryTotal = Number(Astro.url.searchParams.get('total') || 0);
const subtotal = queryTotal > 0 ? queryTotal : marketplaceSubtotal(item, quantity);
const steps = marketplaceSteps(item.id);
const coverage = [
  { label: '结算表单', value: '地址、支付方式、发票、备注' },
  { label: '网络', value: '/api/marketplace/checkout.json POST' },
  { label: '状态', value: '订单号 cookie、结果页链接、输出区域' },
  { label: '兼容性', value: '不依赖真实支付、不跳转第三方站点' },
];
---
<ScenarioLayout title="Marketplace checkout" eyebrow="Step 5" summary="结算页模拟地址确认、支付选择、发票选择、订单提交和结果页跳转。" scenarioId="marketplace-checkout" steps={steps} coverage={coverage}>
  <section class="checkout-shell" data-testid="marketplace-checkout-root" data-item={item.id} data-quantity={quantity} data-total={subtotal}>
    <form id="checkout-form" class="panel checkout-form" data-testid="marketplace-checkout-form">
      <section data-testid="marketplace-address-section">
        <h2>收货地址</h2>
        <div class="choice-grid">
          {marketplaceAddresses.map((address, index) => (
            <label class="choice-card" data-testid="marketplace-address-card">
              <input type="radio" name="addressId" value={address.id} checked={index === 0} data-testid="marketplace-address-radio" />
              <strong>{address.label} · {address.receiver}</strong>
              <span>{address.detail}</span>
              <small>{address.phone} · {address.eta}</small>
            </label>
          ))}
        </div>
      </section>

      <section data-testid="marketplace-payment-section">
        <h2>支付与发票</h2>
        <div class="form-grid">
          <label>支付方式
            <select id="payment" name="payment" data-testid="marketplace-payment-select">
              {marketplacePayments.map((payment) => <option value={payment.id}>{payment.label} · {payment.summary}</option>)}
            </select>
          </label>
          <label>发票
            <select id="invoice" name="invoice" data-testid="marketplace-invoice-select">
              {marketplaceInvoices.map((invoice) => <option value={invoice.id}>{invoice.label}</option>)}
            </select>
          </label>
          <label>买家备注
            <textarea id="buyer-note" name="buyerNote" data-testid="marketplace-buyer-note" rows="3" placeholder="请尽快发货，包装完整。"></textarea>
          </label>
        </div>
      </section>

      <section class="order-lines" data-testid="marketplace-checkout-lines">
        <h2>确认商品</h2>
        <article class="order-line" data-testid="marketplace-checkout-line">
          <strong>{item.title}</strong>
          <span>{item.shop} · 数量 x <b data-testid="marketplace-checkout-quantity">{quantity}</b></span>
          <em data-testid="marketplace-checkout-line-total">¥{subtotal}</em>
        </article>
      </section>
    </form>

    <aside class="panel checkout-summary" data-testid="marketplace-checkout-summary">
      <h2>应付金额</h2>
      <strong id="pay-total" data-testid="marketplace-checkout-total">¥{subtotal}</strong>
      <output id="checkout-output" data-testid="marketplace-checkout-output">order=; status=idle</output>
      <button type="button" id="submit-order" data-testid="marketplace-submit-order">提交订单</button>
      <a id="order-result-link" href="/scenarios/marketplace/order-result" data-testid="marketplace-order-result-link">查看订单结果</a>
    </aside>
  </section>

  <script define:vars={{ itemCount: quantity, total: subtotal }} is:inline>
    const form = document.querySelector('#checkout-form');
    const output = document.querySelector('#checkout-output');
    const resultLink = document.querySelector('#order-result-link');
    const submit = document.querySelector('#submit-order');

    function selectedAddressId() {
      return form?.querySelector('input[name="addressId"]:checked')?.value || 'addr-hangzhou';
    }

    submit?.addEventListener('click', async () => {
      const payment = document.querySelector('#payment')?.value || 'mock-alipay';
      const invoice = document.querySelector('#invoice')?.value || 'personal';
      const buyerNote = document.querySelector('#buyer-note')?.value || '';
      const res = await fetch('/api/marketplace/checkout.json', {
        method: 'POST',
        headers: { 'content-type': 'application/json', 'x-dp-test': 'marketplace-checkout' },
        body: JSON.stringify({ addressId: selectedAddressId(), payment, invoice, buyerNote, itemCount, total }),
      });
      const data = await res.json();
      output.textContent = `order=${data.orderId}; status=${data.status}; total=${data.total}`;
      resultLink.href = data.nextUrl;
      resultLink.textContent = `查看订单 ${data.orderId}`;
      window.__lastMarketplaceOrder = data;
    });
  </script>

  <style>
    .checkout-shell { display: grid; grid-template-columns: minmax(0, 1fr) 320px; gap: 18px; align-items: start; }
    .checkout-form, .checkout-summary { margin-top: 0; }
    .choice-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 12px; }
    .choice-card { display: grid; gap: 8px; padding: 14px; border: 1px solid #fed7aa; border-radius: 14px; background: #fff7ed; cursor: pointer; }
    .choice-card span, .choice-card small { color: #64748b; }
    .form-grid { display: grid; gap: 12px; }
    .form-grid label { display: grid; gap: 6px; color: #475569; }
    .form-grid select, .form-grid textarea { border: 1px solid #cbd5e1; border-radius: 10px; padding: 10px; }
    .order-line { display: grid; grid-template-columns: minmax(0, 1fr) auto auto; gap: 14px; padding: 14px; border: 1px solid #e2e8f0; border-radius: 14px; }
    .order-line em { color: #ea580c; font-style: normal; font-weight: 900; }
    .checkout-summary { position: sticky; top: 18px; display: grid; gap: 12px; border-color: #fed7aa; }
    .checkout-summary strong { color: #ea580c; font-size: 34px; }
    .checkout-summary output { padding: 10px; border-radius: 10px; color: #9a3412; background: #fff7ed; }
    .checkout-summary a { color: #ea580c; font-weight: 800; }
    @media (max-width: 920px) { .checkout-shell, .order-line { grid-template-columns: 1fr; } .checkout-summary { position: static; } }
  </style>
</ScenarioLayout>
