---
import ScenarioLayout from '../../../layouts/ScenarioLayout.astro';
import { searchSocialNotes, socialChannels, socialSteps } from '../../../lib/socialNotes';
import type { SocialChannel } from '../../../lib/socialNotes';

const query = Astro.url.searchParams.get('query') || '';
const channel = (Astro.url.searchParams.get('channel') || 'recommend') as SocialChannel;
const notes = searchSocialNotes({ query, channel, count: 18, offset: 0 });
const steps = socialSteps();
const coverage = [
  { label: '移动端结构', value: '顶部打开 App 条、横向频道、双列瀑布流、底部打开 App 条' },
  { label: '交互', value: '频道切换、搜索、加载更多、详情弹层、点赞收藏关注' },
  { label: '评论', value: '评论列表拉取、评论提交、输出状态' },
  { label: '监控点', value: 'feed/actions/comments API + 安全落地页模拟' },
];
---
<ScenarioLayout title="Social notes mobile flow" eyebrow="Business scenario" summary="社区笔记移动端场景。基于公开 H5 结构抽象为合成瀑布流，不复制真实内容或素材。" scenarioId="social-notes" steps={steps} coverage={coverage}>
  <section class="mobile-shell" data-testid="social-mobile-root" data-channel={channel} data-query={query}>
    <header class="app-open-bar" data-testid="social-mobile-app-bar">
      <div class="app-logo" aria-hidden="true">R</div>
      <div><strong>红盒笔记</strong><span>合成社区笔记测试站</span></div>
      <button type="button" data-testid="social-open-app-top">打开看看</button>
    </header>

    <form class="mobile-search" id="social-search-form" data-testid="social-search-form">
      <input id="social-query" data-testid="social-search-input" value={query} placeholder="搜索 穿搭 / 早餐 / 桌面 / 旅行" />
      <button type="submit" data-testid="social-search-submit">搜索</button>
    </form>

    <nav class="channel-tabs" aria-label="内容频道" data-testid="social-channel-tabs">
      {socialChannels.map((item) => (
        <button type="button" class:list={[item.id === channel && 'active']} data-channel={item.id} data-testid="social-channel-tab">{item.label}</button>
      ))}
    </nav>

    <section class="observe-card" data-testid="social-observation-card">
      <strong>移动 H5 观测抽象</strong>
      <span>固定打开 App 条、频道 filters、热门笔记双列列表、详情/评论弹层、安全落地页。</span>
      <a href="/scenarios/social-notes/security-check?original=/explore/note-404" data-testid="social-security-link">查看安全落地页模拟</a>
    </section>
    <output id="social-app-open-output" data-testid="social-app-open-output">open_app=idle; source=none</output>

    <section class="waterfall-section" data-testid="social-feed-section">
      <h2>热门笔记</h2>
      <div id="social-waterfall" class="waterfall" data-testid="social-waterfall">
        {notes.map((note) => (
          <button type="button" class:list={['note-card', note.aspect]} data-testid="social-note-card" data-note-id={note.id} data-title={note.title} data-author={note.author} data-likes={note.likes} data-collects={note.collects} data-comments={note.comments} data-excerpt={note.excerpt} data-tags={note.tags.join(' ')}>
            <span class="cover" style={`--cover:${note.coverColor}`}>{note.coverLabel}{note.isVideo ? ' · 视频' : ''}</span>
            <strong>{note.title}</strong>
            <span class="excerpt">{note.excerpt}</span>
            <span class="meta"><b>{note.author}</b><em>❤ {note.likes}</em></span>
          </button>
        ))}
      </div>
      <button type="button" id="social-load-more" data-testid="social-load-more">加载更多</button>
      <output id="social-feed-output" data-testid="social-feed-output">visible={notes.length}; loaded={notes.length}; channel={channel}</output>
    </section>

    <footer class="bottom-open" data-testid="social-bottom-open-app">
      <span>打开 App 查看更多互动</span>
      <button type="button" data-testid="social-open-app-bottom">打开</button>
    </footer>
  </section>

  <dialog id="note-sheet" class="note-sheet" data-testid="social-note-sheet">
    <form method="dialog"><button class="close" data-testid="social-close-sheet">×</button></form>
    <div class="sheet-cover" id="sheet-cover" data-testid="social-sheet-cover">笔记</div>
    <h2 id="sheet-title" data-testid="social-sheet-title"></h2>
    <p id="sheet-excerpt" data-testid="social-sheet-excerpt"></p>
    <p id="sheet-tags" class="tags" data-testid="social-sheet-tags"></p>
    <div class="sheet-author"><strong id="sheet-author" data-testid="social-sheet-author"></strong><button type="button" id="follow-author" data-testid="social-follow-author">关注</button></div>
    <div class="sheet-actions" data-testid="social-sheet-actions">
      <button type="button" id="like-note" data-testid="social-like-note">点赞</button>
      <button type="button" id="collect-note" data-testid="social-collect-note">收藏</button>
      <button type="button" id="share-note" data-testid="social-share-note">分享</button>
    </div>
    <output id="social-action-output" data-testid="social-action-output">note=; action=idle</output>
    <section id="comments" data-testid="social-comments-section">
      <h3>评论</h3>
      <div id="comment-list" data-testid="social-comment-list"></div>
      <form id="comment-form" class="comment-form" data-testid="social-comment-form">
        <input id="comment-input" data-testid="social-comment-input" placeholder="写评论" />
        <button type="submit" data-testid="social-comment-submit">发送</button>
      </form>
      <output id="social-comment-output" data-testid="social-comment-output">comments=0; status=idle</output>
    </section>
  </dialog>

  <script is:inline>
    const queryInput = document.querySelector('#social-query');
    const searchForm = document.querySelector('#social-search-form');
    const tabs = document.querySelectorAll('[data-testid="social-channel-tab"]');
    const grid = document.querySelector('#social-waterfall');
    const loadMore = document.querySelector('#social-load-more');
    const feedOutput = document.querySelector('#social-feed-output');
    const sheet = document.querySelector('#note-sheet');
    const sheetTitle = document.querySelector('#sheet-title');
    const sheetExcerpt = document.querySelector('#sheet-excerpt');
    const sheetTags = document.querySelector('#sheet-tags');
    const sheetAuthor = document.querySelector('#sheet-author');
    const actionOutput = document.querySelector('#social-action-output');
    const commentList = document.querySelector('#comment-list');
    const commentForm = document.querySelector('#comment-form');
    const commentInput = document.querySelector('#comment-input');
    const commentOutput = document.querySelector('#social-comment-output');
    const appOpenOutput = document.querySelector('#social-app-open-output');
    let currentChannel = document.querySelector('[data-testid="social-mobile-root"]')?.dataset.channel || 'recommend';
    let loaded = document.querySelectorAll('[data-testid="social-note-card"]').length;
    let activeNoteId = '';

    function cardHtml(note) {
      return `<button type="button" class="note-card ${note.aspect}" data-testid="social-note-card" data-note-id="${note.id}" data-title="${note.title}" data-author="${note.author}" data-likes="${note.likes}" data-collects="${note.collects}" data-comments="${note.comments}" data-excerpt="${note.excerpt}" data-tags="${note.tags.join(' ')}"><span class="cover" style="--cover:${note.coverColor}">${note.coverLabel}${note.isVideo ? ' · 视频' : ''}</span><strong>${note.title}</strong><span class="excerpt">${note.excerpt}</span><span class="meta"><b>${note.author}</b><em>❤ ${note.likes}</em></span></button>`;
    }

    async function fetchFeed({ append = false, offset = 0 } = {}) {
      const params = new URLSearchParams({
        query: queryInput?.value || '',
        channel: currentChannel,
        count: append ? '12' : '18',
        offset: String(offset),
        delay: '20',
      });
      const res = await fetch(`/api/social-notes/feed.json?${params.toString()}`, { headers: { 'x-dp-test': append ? 'social-load-more' : 'social-filter' } });
      const data = await res.json();
      if (!append) {
        grid.innerHTML = '';
        loaded = 0;
      }
      for (const note of data.items) grid.insertAdjacentHTML('beforeend', cardHtml(note));
      loaded += data.items.length;
      feedOutput.textContent = `visible=${document.querySelectorAll('[data-testid="social-note-card"]').length}; loaded=${loaded}; channel=${data.channel}; query=${data.query}; next=${data.nextOffset}`;
    }

    function markOpenApp(source) {
      appOpenOutput.textContent = `open_app=attempted; source=${source}; viewport=${window.innerWidth}x${window.innerHeight}; touch=${navigator.maxTouchPoints || 0}`;
    }

    document.querySelector('[data-testid="social-open-app-top"]')?.addEventListener('click', () => markOpenApp('top'));
    document.querySelector('[data-testid="social-open-app-bottom"]')?.addEventListener('click', () => markOpenApp('bottom'));

    tabs.forEach((tab) => tab.addEventListener('click', async () => {
      currentChannel = tab.dataset.channel || 'recommend';
      tabs.forEach((item) => item.classList.toggle('active', item === tab));
      await fetchFeed({ append: false, offset: 0 });
    }));

    searchForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      await fetchFeed({ append: false, offset: 0 });
    });

    loadMore?.addEventListener('click', async () => {
      await fetchFeed({ append: true, offset: loaded });
    });

    async function renderComments(noteId) {
      const res = await fetch(`/api/social-notes/comments.json?noteId=${encodeURIComponent(noteId)}`, { headers: { 'x-dp-test': 'social-comments' } });
      const data = await res.json();
      commentList.innerHTML = data.comments.map((item) => `<article data-testid="social-comment"><strong>${item.author}</strong><span>${item.text}</span><em>❤ ${item.likes}</em></article>`).join('');
      commentOutput.textContent = `comments=${data.comments.length}; status=loaded`;
    }

    grid?.addEventListener('click', async (event) => {
      const card = event.target.closest('[data-testid="social-note-card"]');
      if (!card) return;
      activeNoteId = card.dataset.noteId;
      sheetTitle.textContent = card.dataset.title;
      sheetExcerpt.textContent = card.dataset.excerpt;
      sheetTags.textContent = card.dataset.tags;
      sheetAuthor.textContent = card.dataset.author;
      actionOutput.textContent = `note=${activeNoteId}; action=open`;
      sheet.showModal();
      await renderComments(activeNoteId);
    });

    async function sendAction(action, enabled = true) {
      if (!activeNoteId) return;
      const res = await fetch('/api/social-notes/actions.json', {
        method: 'POST',
        headers: { 'content-type': 'application/json', 'x-dp-test': `social-${action}` },
        body: JSON.stringify({ noteId: activeNoteId, action, enabled }),
      });
      const data = await res.json();
      actionOutput.textContent = `note=${data.noteId}; action=${data.action}; liked=${data.state.liked}; collected=${data.state.collected}; followed=${data.state.followed}; shared=${data.state.shared}`;
    }

    document.querySelector('#like-note')?.addEventListener('click', () => sendAction('like', true));
    document.querySelector('#collect-note')?.addEventListener('click', () => sendAction('collect', true));
    document.querySelector('#follow-author')?.addEventListener('click', () => sendAction('follow', true));
    document.querySelector('#share-note')?.addEventListener('click', () => sendAction('share', true));

    commentForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const text = commentInput?.value || '';
      const res = await fetch('/api/social-notes/comments.json', {
        method: 'POST',
        headers: { 'content-type': 'application/json', 'x-dp-test': 'social-comment-post' },
        body: JSON.stringify({ noteId: activeNoteId, text }),
      });
      const data = await res.json();
      commentList.insertAdjacentHTML('beforeend', `<article data-testid="social-comment"><strong>${data.comment.author}</strong><span>${data.comment.text}</span><em>❤ 0</em></article>`);
      commentOutput.textContent = `comments=${data.total}; status=posted; text=${data.comment.text}`;
      if (commentInput) commentInput.value = '';
    });
  </script>

  <style>
    .mobile-shell { max-width: 430px; margin: 0 auto; border: 1px solid #fecdd3; border-radius: 26px; overflow: hidden; background: #fff7f8; box-shadow: 0 24px 60px rgba(244, 63, 94, .12); }
    .app-open-bar, .bottom-open { display: grid; grid-template-columns: 42px 1fr auto; gap: 10px; align-items: center; padding: 12px; background: rgba(255,255,255,.96); border-bottom: 1px solid #fecdd3; position: sticky; top: 0; z-index: 2; }
    .app-open-bar span { display: block; color: #64748b; font-size: 12px; }
    .app-logo { display: grid; place-items: center; width: 38px; height: 38px; border-radius: 12px; color: #fff; background: #ff2442; font-weight: 900; }
    .app-open-bar button, .bottom-open button { border-radius: 999px; background: #ff2442; }
    .mobile-search { display: grid; grid-template-columns: 1fr 72px; gap: 8px; padding: 12px; }
    .mobile-search input { border: 1px solid #fecdd3; border-radius: 999px; padding: 10px 14px; background: #fff; }
    .channel-tabs { display: flex; gap: 8px; overflow-x: auto; padding: 0 12px 12px; }
    .channel-tabs button { flex: 0 0 auto; color: #be123c; background: #fff; border: 1px solid #fecdd3; border-radius: 999px; padding: 8px 12px; }
    .channel-tabs button.active { color: #fff; background: #ff2442; }
    .observe-card { display: grid; gap: 6px; margin: 0 12px 12px; padding: 12px; border-radius: 16px; color: #881337; background: #ffe4e6; }
    .observe-card a { color: #be123c; font-weight: 800; }
    .waterfall-section { padding: 0 12px 70px; }
    .waterfall-section h2 { margin: 8px 0 12px; }
    .waterfall { column-count: 2; column-gap: 10px; }
    .note-card { display: inline-grid; width: 100%; gap: 7px; margin: 0 0 10px; padding: 0 0 10px; break-inside: avoid; text-align: left; color: #172033; background: #fff; border: 1px solid #fecdd3; border-radius: 16px; overflow: hidden; }
    .note-card .cover { display: grid; place-items: center; min-height: 150px; color: #fff; font-weight: 900; background: linear-gradient(135deg, var(--cover), #111827); }
    .note-card.tall .cover { min-height: 210px; }
    .note-card.wide .cover { min-height: 116px; }
    .note-card strong, .note-card .excerpt, .note-card .meta { padding: 0 10px; }
    .note-card .excerpt { color: #64748b; font-size: 12px; }
    .note-card .meta { display: flex; justify-content: space-between; gap: 8px; font-size: 12px; }
    .note-card em { color: #ff2442; font-style: normal; }
    #social-load-more { width: 100%; margin: 12px 0; border-radius: 999px; background: #111827; }
    #social-feed-output, #social-action-output, #social-comment-output, #social-app-open-output { display: block; padding: 9px; border-radius: 10px; background: #fff1f2; color: #9f1239; font-size: 12px; }
    #social-app-open-output { margin: 0 12px 12px; }
    .bottom-open { position: sticky; bottom: 0; grid-template-columns: 1fr auto; border-top: 1px solid #fecdd3; border-bottom: 0; }
    .note-sheet { width: min(430px, calc(100vw - 24px)); border: 0; border-radius: 24px 24px 0 0; padding: 16px; box-shadow: 0 -12px 44px rgba(15, 23, 42, .28); }
    .note-sheet::backdrop { background: rgba(15, 23, 42, .46); }
    .close { float: right; width: 36px; height: 36px; border-radius: 999px; background: #111827; }
    .sheet-cover { display: grid; place-items: center; min-height: 180px; margin-top: 26px; border-radius: 18px; color: #fff; background: linear-gradient(135deg, #ff2442, #111827); font-weight: 900; }
    .tags { color: #be123c; }
    .sheet-author, .sheet-actions, .comment-form { display: flex; gap: 8px; align-items: center; }
    .sheet-author { justify-content: space-between; }
    .sheet-actions button, #follow-author { border-radius: 999px; background: #ff2442; }
    #comment-list { display: grid; gap: 8px; margin: 12px 0; }
    #comment-list article { display: grid; gap: 4px; padding: 10px; border-radius: 12px; background: #f8fafc; }
    #comment-list em { color: #ff2442; font-style: normal; }
    .comment-form input { flex: 1; border: 1px solid #fecdd3; border-radius: 999px; padding: 10px 14px; }
    @media (min-width: 760px) { .mobile-shell { transform-origin: top center; } }
  </style>
</ScenarioLayout>
